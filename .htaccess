Options -Indexes
DirectoryIndex index.html tinyblog.php

<IfModule mod_headers.c>
  # Keep in sync with tinyblog.php::security_headers(); customize CSP if adding third-party services.
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^uploads/ - [L]
  RewriteRule ^assets/ - [L]
  RewriteRule ^tinyblog-widget\.js$ - [L]
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^(README|SETUP|SECURITY)\.md$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ tinyblog.php [L]
</IfModule>

<FilesMatch "^(.*\.db|.*\.sqlite|.*\.sqlite3|.*\.log|\.env)$">
  Require all denied
</FilesMatch>

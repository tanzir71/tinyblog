# Copy to .env on the server if you need non-default paths or thresholds.
# Do not commit .env. The included .gitignore excludes it.
TB_DB_PATH=./data/tinyblog.db
TB_UPLOAD_DIR=./uploads
TB_LOG_FILE=./data/tinyblog.log
TB_SESSION_TIMEOUT=1800
TB_LOGIN_RATE_LIMIT=10
TB_SUBSCRIBE_RATE_LIMIT=5
TB_MAX_UPLOAD_BYTES=2097152

# Optional backend-editable admin credentials.
# Edit these in cPanel/File Manager or another private server file editor,
# then log in at /admin. Leave blank to use browser first-admin setup.
# TB_ADMIN_EMAIL=owner@example.com
# TB_ADMIN_NAME=Owner
# TB_ADMIN_PASSWORD=change-this-long-password
# Or use a PHP password_hash() value instead of TB_ADMIN_PASSWORD:
# TB_ADMIN_PASSWORD_HASH=

# Copy to .env on the server if you need non-default paths or thresholds.
# Do not commit .env. The included .gitignore excludes it.
TB_DB_PATH=./data/tinyblog.db
TB_UPLOAD_DIR=./uploads
TB_LOG_FILE=./data/tinyblog.log
TB_SESSION_TIMEOUT=1800
TB_LOGIN_RATE_LIMIT=10
TB_SUBSCRIBE_RATE_LIMIT=5
TB_MAX_UPLOAD_BYTES=2097152
